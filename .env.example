GEMINI_API_KEY=your_api_key_here
# Optional — defaults to gemini-2.5-flash (fast). Examples: gemini-2.5-flash, gemini-3.1-flash-lite-preview
# GEMINI_MODEL=gemini-2.5-flash

# Backend — extra allowed CORS origin (Railway). Netlify URL is included by default.
# FRONTEND_URL=https://travel-agent-chat.netlify.app

# Frontend — base URL for Find trains handoff (journeys-grid)
VITE_JOURNEYS_BASE_URL=https://southeastern.stage.otrl.io

# Frontend — backend API URL (required on Netlify; leave empty for local dev proxy)
# VITE_API_BASE_URL=https://travel-agent-production-06ce.up.railway.app
